# Copy to .env and customize for your deployment
ISS_API_URL=https://api.wheretheiss.at/v1/satellites/25544

# Optional: N2YO fallback API key (free registration at https://www.n2yo.com/api/)
# When set, N2YO is used as a fallback if the primary API fails.
N2YO_API_KEY=

# GPIO pin for the view toggle switch (optional, wire between this pin and GND)
GPIO_TOGGLE=17
# Set to false if no toggle switch is wired; DEFAULT_VIEW will be used instead
TOGGLE_SWITCH_ENABLED=true

PREVIEW_ONLY=false
ISS_PREVIEW_DIR=var/previews

# Default view when no toggle switch is wired: "iss" (globe/tracker) or "crew"
DEFAULT_VIEW=iss
